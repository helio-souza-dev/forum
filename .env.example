# ==============================================================================
# PRISMSHARE - CONFIGURAÇÕES E VARIÁVEIS DE AMBIENTE (.env.example)
# Copie este arquivo para .env e preencha com as suas configurações
# ==============================================================================

# Porta em que o servidor backend rodará local ou em produção (padrão: 3001)
PORT=3001

# String de Conexão com MongoDB Atlas (Opcional)
# Se deixado em branco, o sistema funciona 100% no modo arquivo local (server/data/db.json)
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/prismshare?retryWrites=true&w=majority

# Segredo para assinatura de Tokens JWT de autenticação
# Se não definido, o servidor gera automaticamente um segredo em server/data/jwt_secret.txt
PRISMSHARE_JWT_SECRET=super_segredo_aleatorio_seguro_e_longo_para_sua_plataforma

# Senha fixa para a conta de administrador/desenvolvedor "dev" criada no primeiro boot
# Se não definida, o console do servidor exibirá uma senha gerada aleatoriamente uma única vez
PRISMSHARE_DEV_PASSWORD=sua_senha_secreta_de_dev_aqui
